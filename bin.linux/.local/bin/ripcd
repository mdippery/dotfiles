#!/bin/bash

set -e
set -o pipefail

cdparanoia -vsQ

read -p 'Continue? [Y/n] ' -n 1 -r
echo
if [[ ! $REPLY == 'Y' ]]; then
  exit 1
fi

echo 'Ripping CD...'
cdparanoia -B

echo 'Converting to MP3 VBR V0...'
for wav in *.wav; do
  lame -V 0 -B 320 $wav $wav.mp3
done

echo 'Tarring MP3s...'
tar cf "${PWD##*/}.tar" *.mp3

echo 'Done!'
