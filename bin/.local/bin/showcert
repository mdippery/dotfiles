#!/bin/bash

set -o pipefail

# Believe it or not, this echo is necessary -- otherwise the script hangs
# for a couple of seconds before returning to the prompt. Why? I dunno.
echo \
  | openssl s_client -showcerts -servername $1 -connect $1:443 2>/dev/null \
  | openssl x509 -inform pem -noout -text
