#!/usr/bin/env python

import datetime
import sys


def get_year(argv):
    try:
        return int(argv[1])
    except IndexError:
        return datetime.date.today().year


def get_easter(year):
    """Calculates Easter in any year using the Meeus/Jones/Butcher algorithm."""
    a = year % 19
    b = year // 100
    c = year % 100
    d = b // 4
    e = b % 4
    f = (b + 8) // 25
    g = (b - f + 1) // 3
    h = (19 * a + b - d - g + 15) % 30
    i = c // 4
    k = c % 4
    l = (32 + 2 * e + 2 * i - h - k) % 7
    m = (a + 11 * h + 22 * l) // 451
    month = (h + l - 7 * m + 114) // 31
    day = (( h + l - 7 * m + 114) % 31) + 1
    return datetime.date(year, month, day)


year = get_year(sys.argv)
easter = get_easter(year)
print(easter.strftime("%c").replace("00:00:00 ", "").replace("  ", " "))
