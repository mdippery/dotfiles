#!/usr/bin/env python

import os.path
import sys
import urllib.parse as P

parsers = dict(urlencode=P.quote, urldecode=P.unquote)
script = os.path.basename(sys.argv[0])

try:
    string = sys.argv[1]
except IndexError:
    string = sys.stdin.read().strip()

try:
    print(parsers[script](string))
except KeyError:
    print(f"Unknown URL tool: {script}", file=sys.stderr)
    sys.exit(1)
