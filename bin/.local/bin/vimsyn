#!/usr/bin/env python

import shutil
from pathlib import Path

from plumbum.cmd import vim, egrep, find, head, sort, tr


def binroot(exe):
    path = shutil.which(exe)
    return Path(path).parent.parent


vim_version = (
    vim["--version"]
    | head["-n", "1"]
    | egrep["-o", r"([0-9]+\.[0-9])"]
    | tr["-d", "."]
)().strip()

vim_root = binroot("vim")
macvim = Path("/") / "Applications" / "MacVim.app" / "Contents"
if vim_root == macvim:
    syn_root = macvim / "Resources" / "vim" / "runtime" / "syntax"
else:
    syn_root = vim_root / "share" / "vim" / f"vim{vim_version}" / "syntax"


syntaxes = (
    find[str(syn_root), "-name", "*.vim", "-exec", "basename", "{}", ";"]
    | sort
)().strip()
print(syntaxes)
