#!/bin/bash

set -euo pipefail

bw() {
  local in
  local out

  while getopts o: opt; do
    case $opt in
      o) out=$OPTARG;;
      *) echo "invalid args: $*" 1>&2; exit 1;
    esac
  done

  shift $((OPTIND - 1))
  in=$1

  if [ -z "$in" ]; then
    echo "no infile specified" 1>&2
    exit 1
  fi

  if [ -z "$out" ]; then
    echo "no outfile specified" 1>&2
    exit 1
  fi

  magick "$in" -grayscale Rec709Luma -contrast-stretch 3%x3% "$out"
}

cmd=$1
shift

$cmd $*
