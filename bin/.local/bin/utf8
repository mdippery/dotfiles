#!/usr/bin/env python

# Prints the bash utf8 representation of a character
#
# In straight bash, this would be:
#
#   echo -n "$1" \
#     | hexdump -b \
#     | head -n 1 \
#     | awk '{ for (i = 1; ++i <= NF;) printf "\\%s", $i; } END { print " " }'
#
# but I think this Python version is easier to read.

import argparse
import sys
import unicodedata


def single_character(s):
    if len(s) > 1:
        raise ValueError("character must be a single character")
    return s


DESCRIPTION = """\
Prints the bytes that make up a UTF-8 character in a form that is used by bash.
Optionally shows the Unicode name of the character as well.
"""

parser = argparse.ArgumentParser(
    prog="utf8",
    description=DESCRIPTION,
)
parser.add_argument(
    "-b", "--bash",
    action="store_true",
    # No way to turn this off but I'm not sure of the UX here.
    default=False,
    help="display the bash representation of the character",
)
parser.add_argument(
    "-u", "--unicode",
    action="store_true",
    default=False,
    help="display the Unicode name of the character",
)
parser.add_argument(
    "-v", "--verbose",
    action="store_true",
    default=False,
    help="verbose output",
)
parser.add_argument(
    "character",
    type=single_character,
    help="the character",
)

args = parser.parse_args()

ch = args.character

if args.unicode:
    if args.verbose:
        print("Unicode Name:", end="\t")
    print(unicodedata.name(ch))

if args.bash:
    if args.verbose:
        print("Bash:", end="\t\t")
    bn = ch.encode("utf-8")
    bs = "".join(oct(b).replace("0o", "\\") for b in bn)
    print(bs)
