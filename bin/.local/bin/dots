#!/bin/bash

set -e

function dots_directory {
  case "$1" in
    dots) echo $DOTFILES ;;
    vims) echo $VIMFILES ;;

    *)
      onoe "No dots directory: $1"
      return 1
  esac
}

function dots_exec {
  local dots_dir git_dir
  dots_dir=$(dots_directory $1)
  git_dir=$dots_dir/.git
  shift
  case "$1" in
    ln)
      shift
      exec stow -d $dots_dir $*
      ;;
    rm)
      shift
      exec stow -D -d $dots_dir $*
      ;;
    up)
      exec git --git-dir=$git_dir --work-tree=$dots_dir pull
      ;;
    *)
      exec git --git-dir=$git_dir --work-tree=$dots_dir $*
      ;;
  esac
}

dots_type=$(basename $0)
dots_exec $dots_type $*
