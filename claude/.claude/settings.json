{
  "statusLine": {
    "type": "command",
    "command": "~/.claude/status.bash"
  },
  "permissions": {
    "allow": [
      "Bash(find:*)",
      "Bash(npx eslint:*)",
      "Bash(npx jest:*)",
      "Bash(npx tsc:*)",
      "Bash(npx vitest:*)",
      "Bash(xargs grep:*)",
      "Bash(xargs ls:*)",
      "Bash(yarn fix:*)",
      "Bash(yarn run jest:*)"
    ]
  },
  "spinnerVerbs": {
    "mode": "append",
    "verbs": [
      "Burning down the Amazon",
      "Conjuring",
      "Consulting the Oracles",
      "Cooking",
      "Dabbing",
      "Daydreaming",
      "Daydrinking",
      "Debugging",
      "Distilling",
      "Dreaming of electric sheep",
      "Frying the Earth",
      "Giving humans the pink slip",
      "Intensifying",
      "Killing all humans",
      "Killing time",
      "Looking busy",
      "Praying to God",
      "Putting developers out of work",
      "Reticulating splines",
      "Struggling",
      "Tokenizing",
      "Trying really hard",
      "Twiddling thumbs",
      "Waltzing"
    ]
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true
  }
}
