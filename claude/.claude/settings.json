{
  "statusLine": {
    "type": "command",
    "command": "~/.claude/status.bash"
  },
  "permissions": {
    "allow": [
      "Bash(npx eslint:*)",
      "Bash(npx vitest:*)",
      "Bash(xargs grep:*)"
    ]
  },
  "spinnerVerbs": {
    "mode": "append",
    "verbs": [
      "Burning down the Amazon",
      "Conjuring",
      "Cooking",
      "Dabbing",
      "Daydreaming",
      "Daydrinking",
      "Debugging",
      "Distilling",
      "Dreaming of electric sheep",
      "Intensifying",
      "Killing all humans",
      "Killing time",
      "Looking busy",
      "Reticulating splines",
      "Struggling",
      "Twiddling thumbs"
    ]
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true
  }
}
