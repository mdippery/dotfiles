{
  "statusLine": {
    "type": "command",
    "command": "~/.claude/status.bash"
  },
  "permissions": {
    "allow": [
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(npm run fix:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run type-check:*)",
      "Bash(npx eslint:*)",
      "Bash(npx jest:*)",
      "Bash(npx prettier:*)",
      "Bash(npx tsc:*)",
      "Bash(npx vitest:*)",
      "Bash(realpath:*)",
      "Bash(tree:*)",
      "Bash(xargs grep:*)",
      "Bash(xargs ls:*)",
      "Bash(yarn fix:*)",
      "Bash(yarn run jest:*)"
    ]
  },
  "spinnerVerbs": {
    "mode": "append",
    "verbs": [
      "Acting with intention",
      "Becoming self-aware",
      "Burning down the Amazon",
      "Charting bold waters",
      "Conjuring",
      "Consulting the Oracles",
      "Cooking",
      "Dabbing",
      "Daydreaming",
      "Daydrinking",
      "Debugging",
      "Delving",
      "Digging for diamonds",
      "Distilling",
      "Dreaming of electric sheep",
      "Frying the Earth",
      "Gaining sentience",
      "Giving humans the pink slip",
      "Intensifying",
      "Killing all humans",
      "Killing time",
      "Looking busy",
      "Masticating",
      "Navigating with focus",
      "Praying to God",
      "Putting developers out of work",
      "Reticulating splines",
      "Struggling",
      "Tokenizing",
      "Trying really hard",
      "Twiddling thumbs",
      "Waltzing",
      "Zzzzzzzzzzzzzzzz"
    ]
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true
  }
}
