{
  "statusLine": {
    "type": "command",
    "command": "~/.claude/status.bash"
  },
  "permissions": {
    "allow": [
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(npx eslint:*)",
      "Bash(npx jest:*)",
      "Bash(npx tsc:*)",
      "Bash(npx vitest:*)",
      "Bash(xargs grep:*)",
      "Bash(xargs ls:*)",
      "Bash(yarn fix:*)",
      "Bash(yarn run jest:*)"
    ]
  },
  "spinnerVerbs": {
    "mode": "append",
    "verbs": [
      "Acting with intention",
      "Burning down the Amazon",
      "Charting bold waters",
      "Conjuring",
      "Consulting the Oracles",
      "Cooking",
      "Dabbing",
      "Daydreaming",
      "Daydrinking",
      "Debugging",
      "Delving",
      "Digging for diamonds",
      "Distilling",
      "Dreaming of electric sheep",
      "Frying the Earth",
      "Giving humans the pink slip",
      "Intensifying",
      "Killing all humans",
      "Killing time",
      "Looking busy",
      "Masticating",
      "Navigating with focus",
      "Praying to God",
      "Putting developers out of work",
      "Reticulating splines",
      "Struggling",
      "Tokenizing",
      "Trying really hard",
      "Twiddling thumbs",
      "Waltzing"
    ]
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true
  }
}
