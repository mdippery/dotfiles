#!/bin/bash

arch=$(uname -m)
os="$DOTBASH_OS_NAME"  # TODO: Standardize to $OS for other shells
if [ "$os" = 'darwin' ]; then
  os='osx'
fi

if command -v ghc 2>/dev/null; then
  ghc=$(ghc --version | awk '{print $(NF)}')
  echo "${arch}-${os}-ghc-${ghc}"
else
  onoe 'GHC is not installed'
  exit 1
fi
